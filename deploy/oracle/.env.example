BONACA_DATABASE_URL=jdbc:postgresql://postgres:5432/bonaca
BONACA_DATABASE_USER=bonaca
BONACA_DATABASE_PASSWORD=
JWT_SECRET=
BACKEND_SECRET=
# Optional — leave unset (or blank) to use LoggingOtpSender (OTPs logged to console).
# Set both to activate MSG91 real SMS delivery.
# Spring maps BONACA_MSG91_AUTH_KEY → bonaca.msg91.auth-key via relaxed binding.
BONACA_MSG91_AUTH_KEY=
BONACA_MSG91_TEMPLATE_ID=
