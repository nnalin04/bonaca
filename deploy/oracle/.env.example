BONACA_DATABASE_URL=jdbc:postgresql://postgres:5432/bonaca
BONACA_DATABASE_USER=bonaca
BONACA_DATABASE_PASSWORD=
JWT_SECRET=
BACKEND_SECRET=

# SMS — OTPs logged to console until both are set. Requires DLT registration first.
# Spring relaxed binding: BONACA_MSG91_AUTH_KEY → bonaca.msg91.auth-key
BONACA_MSG91_AUTH_KEY=
BONACA_MSG91_TEMPLATE_ID=

# Wearable sync — requires Spike API access (spike.sh). Both must be set to activate.
BONACA_SPIKE_API_KEY=
BONACA_SPIKE_WEBHOOK_SECRET=

# Payments — requires Razorpay account + KYC + plan creation. All four must be set.
BONACA_RAZORPAY_KEY_ID=
BONACA_RAZORPAY_KEY_SECRET=
BONACA_RAZORPAY_WEBHOOK_SECRET=
BONACA_RAZORPAY_PLAN_ID=
